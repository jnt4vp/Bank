# Copy this file to /opt/bankapp/.env.prod on EC2 and replace secure values.

JWT_SECRET=replace-with-openssl-rand-hex-32
DB_PASSWORD=replace-with-openssl-rand-hex-16

# Optional overrides
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
OLLAMA_ENABLED=true
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b

# Public URL of your deployed SPA — used in password-reset links
# FRONTEND_URL=https://your-domain-or-ec2-ip

# Gmail SMTP (required for any outbound mail: alerts, forgot-password, accountability)
# Use an App Password (Google Account → Security → 2-Step Verification → App passwords),
# not your normal Gmail password.
# GMAIL_USER=your-bot@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Optional fallback when no user email (transaction alerts)
# ALERT_EMAIL=fallback@example.com

# Plaid — get credentials at https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_POLL_INTERVAL_MINUTES=30

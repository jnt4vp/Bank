APP_ENV=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bank
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
SQL_ECHO=false
AUTO_CREATE_TABLES=false
# JSON array or comma-separated list
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# LLM classifier (Ollama)
OLLAMA_ENABLED=true
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# Gmail SMTP — alert emails
GMAIL_USER=your-sending-account@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
ALERT_EMAIL=fallback@example.com

# Development seed user
DEV_SEED_EXAMPLE_USER=true
DEV_SEED_EXAMPLE_NAME=Test User
DEV_SEED_EXAMPLE_EMAIL=test@example.com
DEV_SEED_EXAMPLE_PASSWORD=password123
